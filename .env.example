AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project
AZURE_AI_AGENT_NAME=your-agent-name
# Optional
AZURE_AI_MODEL=gpt-4.1-mini
# Optional auth overrides
# AZURE_AUTH_MODE=devicecode
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# API key from Azure Key Vault
AZURE_AUTH_MODE=apikey
AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
AZURE_API_KEY_SECRET_NAME=your-secret-name
